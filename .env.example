# ─────────────────────────────────────────────────────────────────
# Event Planning OS — Marketing Website
# ─────────────────────────────────────────────────────────────────

# Public URL of the main Event Planning OS app (Railway production URL)
# All "Start free trial" / "Sign in" CTAs link to this base URL
NEXT_PUBLIC_APP_URL=https://app.elation.events

# Public URL of this marketing site (custom domain)
# Used for sitemap.xml, robots.txt, and OpenGraph meta tags
NEXT_PUBLIC_SITE_URL=https://elation.events

# ─────────────────────────────────────────────────────────────────
# Contact form (Resend)
# ─────────────────────────────────────────────────────────────────
# Get your API key at https://resend.com
# Leave blank to disable email sending (form submissions will be logged only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_EMAIL=hello@elation.events
